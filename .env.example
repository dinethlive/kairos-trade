# Deriv Personal Access Token
# Create one at https://app.deriv.com/account/api-token
# Required scopes: Read, Trade, Trading Information, Payments
KAIROS_TRADE_TOKEN=

# Deriv App ID (default provided — override if yours is different)
KAIROS_TRADE_APP_ID=

# Optional: pin a specific account (e.g. DOT9000XXXX). If blank, kairos-trade picks
# the first active DEMO account. Use /accounts inside the REPL to list yours.
KAIROS_TRADE_ACCOUNT_ID=

# Trading defaults (all optional — CLI flags override these)
KAIROS_TRADE_SYMBOL=1HZ100V
KAIROS_TRADE_STAKE=0.35
KAIROS_TRADE_DURATION=5
KAIROS_TRADE_SENSITIVITY=medium
KAIROS_TRADE_MIN_STRENGTH=2

# Martingale (loss-recovery stake scaling)
KAIROS_TRADE_MG=classic
KAIROS_TRADE_MG_MULT=2.2
KAIROS_TRADE_MG_MAX_STEPS=8
KAIROS_TRADE_MG_ARM_AFTER=2
KAIROS_TRADE_MG_MAX_STAKE=off
KAIROS_TRADE_MG_STOP_LOSS=200
KAIROS_TRADE_MG_TAKE_PROFIT=off
KAIROS_TRADE_MG_ON_CAP=reset
