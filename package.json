{
  "name": "kairos-trade",
  "version": "0.2.0",
  "description": "Tick-based adaptive auto-trading CLI for Deriv synthetic indices",
  "keywords": ["deriv", "trading", "bun", "ink", "cli", "synthetic-indices"],
  "author": "dinethlive <dinethlive@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dinethlive/kairos-trade.git"
  },
  "type": "module",
  "bin": {
    "kairos-trade": "./src/index.tsx"
  },
  "scripts": {
    "start": "bun src/index.tsx",
    "dev": "bun --watch src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build": "bun build src/index.tsx --compile --outfile dist/kairos-trade.exe",
    "link": "bun link"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3"
  }
}
