{
  "name": "kairos-trade",
  "version": "0.1.0",
  "description": "Tick-based adaptive auto-trading CLI for Deriv synthetic indices",
  "type": "module",
  "bin": {
    "kairos-trade": "./src/index.tsx"
  },
  "scripts": {
    "start": "bun src/index.tsx",
    "dev": "bun --watch src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build": "bun build src/index.tsx --compile --outfile dist/kairos-trade.exe",
    "link": "bun link"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1",
    "zustand": "^5.0.2"
  }
}
